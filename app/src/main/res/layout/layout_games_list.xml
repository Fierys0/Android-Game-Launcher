<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:clipToPadding="false"
    android:paddingBottom="100dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Steam Hero Banner (Vertical Rect with overlay) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/heroCard"
            android:layout_width="match_parent"
            android:layout_height="@dimen/hero_height"
            android:layout_margin="16dp"
            app:cardBackgroundColor="@color/card_surface"
            app:cardCornerRadius="@dimen/card_radius"
            app:strokeWidth="1dp"
            app:strokeColor="@color/transparent_white_10">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <ImageView
                    android:id="@+id/ivHero"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/placeholder"
                    android:contentDescription="@null" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/steam_gradient_overlay" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@color/primary"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="4dp"
                        android:text="FEATURED"
                        android:textColor="@color/white"
                        android:textSize="@dimen/text_tiny"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvHeroTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Cyberpunk 2077"
                        android:textColor="@color/white"
                        android:textSize="@dimen/text_title"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvHeroDesc"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:ellipsize="end"
                        android:maxLines="2"
                        android:text="Experience the dystopian future of Night City."
                        android:textColor="#B3FFFFFF"
                        android:textSize="@dimen/text_small" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnGetNow"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="GET NOW"
                        android:textColor="@color/black"
                        app:backgroundTint="@color/white"
                        app:cornerRadius="@dimen/button_radius" />
                </LinearLayout>
            </FrameLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            android:text="Popular &amp; Recommended"
            android:textColor="?attr/colorOnSurface"
            android:textSize="@dimen/text_large"
            android:textStyle="bold"
            android:letterSpacing="0.05" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvGames"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipToPadding="false"
            android:paddingHorizontal="16dp"
            android:paddingVertical="16dp"
            android:orientation="horizontal"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            tools:listitem="@layout/item_game_poster" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="24dp"
            android:text="More to Discover"
            android:textColor="?attr/colorOnSurface"
            android:textSize="@dimen/text_large"
            android:textStyle="bold"
            android:letterSpacing="0.05" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvGamesGrid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipToPadding="false"
            android:paddingHorizontal="8dp"
            android:paddingVertical="16dp"
            app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
            app:spanCount="2"
            tools:listitem="@layout/item_game_grid" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
